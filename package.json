{
  "name": "celiacsafe",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "powershell -ExecutionPolicy Bypass -File scripts/start-tunnel.ps1",
    "start:tunnel": "powershell -ExecutionPolicy Bypass -File scripts/start-tunnel.ps1",
    "start:lan": "powershell -ExecutionPolicy Bypass -File scripts/start-lan.ps1",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "web:export": "expo export --platform web && node scripts/post-web-export.mjs",
    "web:preview": "npm run web:export && npx serve dist",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "data:build": "python scripts/excel-to-json.py -i data-source/CeliacSafe_Datenbank_v4_Spain_129_geocoded.xlsx -i data-source/CeliacSafe_Datenbank_v4_Germany_100GF_Geocoded_Seed.xlsx -o src/data/restaurants.json",
    "data:excel-template": "python scripts/create-excel-template.py",
    "data:upgrade-excel": "python scripts/upgrade-excel-schema.py",
    "data:enrich-excel": "python scripts/enrich-excel-links.py",
    "data:enrich-excel:inplace": "python scripts/enrich-excel-links.py --in-place",
    "data:export-supabase": "node scripts/export-from-supabase.mjs",
    "data:import-supabase": "node scripts/import-to-supabase.mjs",
    "data:delete-legacy": "node scripts/delete-legacy-restaurants.mjs",
    "supabase:setup-admin": "node scripts/setup-admin.mjs",
    "data:import-supabase:py": "python scripts/import-to-supabase.py",
    "supabase:migrate": "node scripts/run-supabase-migrations.mjs",
    "supabase:migrate:security": "node scripts/run-supabase-migrations.mjs --from=005",
    "supabase:verify-security": "node scripts/verify-security-migration.mjs",
    "supabase:apply-pending": "node scripts/apply-pending-sql.mjs",
    "admin:dev": "npm run dev --prefix admin-web",
    "geocode": "python scripts/geocode.py data-source/CeliacSafe_Datenbank_v3.xlsx data-source/CeliacSafe_Datenbank_v4.xlsx",
    "assets:generate": "node scripts/generate-brand-assets.mjs",
    "assets:venue-photos": "node scripts/download-venue-type-photos.mjs",
    "test": "jest"
  },
  "dependencies": {
    "@expo-google-fonts/fraunces": "^0.4.1",
    "@expo-google-fonts/inter-tight": "^0.4.2",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.16.1",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.16.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "expo": "~54.0.35",
    "expo-application": "~7.0.8",
    "expo-asset": "~12.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~56.0.5",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-localization": "~17.0.9",
    "expo-location": "~19.0.8",
    "expo-mail-composer": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.9",
    "i18next": "^26.3.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.85.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-i18next": "^6.1.4",
    "jest-expo": "~54.0.17",
    "pg": "^8.21.0",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo"
  }
}
