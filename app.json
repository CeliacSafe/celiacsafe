{
  "expo": {
    "name": "Celiac Safe",
    "slug": "celiacsafe",
    "scheme": "celiacsafe",
    "version": "0.9.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#5a6850"
    },
    "backgroundColor": "#fdfaf2",
    "updates": {
      "enabled": false
    },
    "ios": {
      "icon": "./assets/icon.png",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Necesitamos tu ubicación para mostrar los restaurantes sin gluten cercanos."
      }
    },
    "android": {
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-fg.png",
        "backgroundColor": "#5a6850",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "name": "Celiac Safe",
      "shortName": "CeliacSafe",
      "themeColor": "#5a6850",
      "backgroundColor": "#fdfaf2"
    },
    "plugins": [
      "expo-font",
      "expo-asset",
      "expo-localization",
      "expo-mail-composer",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#5a6850"
        }
      ]
    ]
  }
}
